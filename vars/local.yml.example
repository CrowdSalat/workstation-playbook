---
# Copy this file to vars/local.yml and fill in your values.
# vars/local.yml is git-ignored and never committed.

# Path to the SSH public key used for commit signing:
git_signing_key: "{{ ansible_facts['env']['HOME'] }}/.ssh/id_ed25519.pub"

# Optional — ssh_agent role (see README):
# ssh_agent_identities: [id_ed25519]
# ssh_agent_enabled: false
# ssh_agent_manage_ssh_config: false
